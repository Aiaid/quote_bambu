# Copy to .env and fill in: cp .env.example .env

# --- P2S printer (LAN) ---
PRINTER_IP=192.168.1.50
PRINTER_SN=
PRINTER_ACCESS=

# --- Quote/0 device ---
QUOTE0_API_KEY=
QUOTE0_DEVICE_ID=

# --- Behavior ---
INTERVAL_SECONDS=60
SHOW_CAMERA=true
# Camera protocol. auto = probe port 322 first then fallback to JPEG/6000.
#   rtsps : P2S, X1 series, H2 series          (ffmpeg -> port 322)
#   jpeg  : P1P, P1S, A1, A1 mini              (raw TLS  -> port 6000)
CAMERA_PROTO=auto

# Comma-separated HMS ecodes (16-hex uppercase, no separator) to never
# full-screen as ALERT — for persistent / benign warnings you don't want
# blocking the normal layout. Example:
# HMS_IGNORE=0500060000020070
HMS_IGNORE=
